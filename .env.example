# uLern-Polish Backend Configuration

PORT=5000
CORS_ORIGIN=http://localhost:5000
NODE_ENV=development

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key
OPENAI_MODEL=openai/gpt-4o-mini

# ElevenLabs API Configuration
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# RunPod Whisper STT Configuration
RUNPOD_WHISPER_API_KEY=your_runpod_whisper_api_key
RUNPOD_WHISPER_API_URL=https://your-runpod-whisper-endpoint.gateway.runpod.xyz
RUNPOD_WHISPER_ENDPOINT_ID=your_whisper_endpoint_id

# RunPod ComfyUI (AI Image Generation)
RUNPOD_COMFY_API_KEY=your_runpod_api_key
RUNPOD_COMFY_API_URL=https://api.runpod.io/v2/rpa_YOUR_ENDPOINT_ID

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_monthly_placeholder
NEXT_PUBLIC_STRIPE_PRICE_PRO_ANNUAL=price_annual_placeholder

# Supabase Configuration (Auth + Database)
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# RunPod Account API Key (for deploying via API)
RUNPOD_ACCOUNT_API_KEY=your_runpod_account_api_key
