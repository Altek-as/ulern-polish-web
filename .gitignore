# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# ---------------------------------------------------
# KEEP CONFIG FILES TRACKED: package.json, tsconfig.json,
# next.config.ts, eslint.config.mjs, postcss.config.mjs
# These are required for `npm ci` and the project to build.
# ---------------------------------------------------

# env files — NEVER commit these (must be FIRST to ensure they override everything)
.env
.env.local
.env.* 
# Exception: .env.example IS tracked — it serves as a project template for new developers
!.env.example

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Generated lesson visuals (ComfyUI output)
outputs/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# VR public assets (minimal — WebXR entry point)
# NOTE: root-level public assets ARE tracked (not gitignored)
/public/index.html
/public/app.js
/public/style.css
/tests/
/playwright-report/
/test-results/
dev-server.*
dev.log
server.log
package.json.backup
playwright.config.ts
README.md
.sisyphus/
