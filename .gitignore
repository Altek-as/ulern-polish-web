# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit these
.env
.env.local
.env.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# VR project - excluded Next.js source files
/app/
/components/
/lib/
!/public/index.html
!/public/app.js
!/public/style.css
/tests/
/playwright-report/
/test-results/
dev-server.*
dev.log
server.log
next.config.ts
tsconfig.json
eslint.config.mjs
postcss.config.mjs
package.json
package-lock.json
package.json.backup
playwright.config.ts
